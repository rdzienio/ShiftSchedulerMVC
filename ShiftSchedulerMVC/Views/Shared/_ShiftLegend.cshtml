@model bool

<p>
    <strong>Legenda:</strong>
    <span class="legend-swatch shift-morning">1</span> poranna,
    <span class="legend-swatch shift-afternoon">2</span> popołudniowa,
    <span class="legend-swatch shift-night">3</span> nocna,
    <span class="legend-swatch shift-leave">@Html.Raw(Model ? "U" : "&nbsp;")</span> urlop
    @if (Model)
    {
        <text>, <span class="legend-swatch shift-free">W</span> wolne</text>
    }
</p>
