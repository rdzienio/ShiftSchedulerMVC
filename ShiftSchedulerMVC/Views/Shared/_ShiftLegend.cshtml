@model bool

<p>
    <strong>Legenda:</strong>
    <span class="legend-swatch shift-morning">1</span> poranna (@ShiftDisplay.TimeRange(ShiftType.Morning)),
    <span class="legend-swatch shift-afternoon">2</span> popołudniowa (@ShiftDisplay.TimeRange(ShiftType.Afternoon)),
    <span class="legend-swatch shift-night">3</span> nocna (@ShiftDisplay.TimeRange(ShiftType.Night)),
    <span class="legend-swatch shift-day12">D</span> dzienna 12h (@ShiftDisplay.TimeRange(ShiftType.Day12)),
    <span class="legend-swatch shift-night12">N</span> nocna 12h (@ShiftDisplay.TimeRange(ShiftType.Night12)),
    <span class="legend-swatch shift-leave">@Html.Raw(Model ? "U" : "&nbsp;")</span> urlop
    @if (Model)
    {
        <text>, <span class="legend-swatch shift-free">W</span> wolne</text>
    }
</p>
