@model List<ShiftSchedulerMVC.Models.UserViewModel>
@{
    ViewData["Title"] = "Panel administratora";
    var availableRoles = ViewBag.AvailableRoles as List<string> ?? new List<string>();
    var selectedRole = ViewBag.RoleFilter as string ?? "";
}


<h2>Użytkownicy</h2>

<a asp-action="Create" class="btn btn-success">Dodaj użytkownika</a>


<form method="get" asp-controller="Admin" asp-action="Index" class="mb-3">
    <label for="roleFilter">Filtruj po roli:</label>
    <select id="roleFilter" name="roleFilter" onchange="this.form.submit()" class="form-select w-auto d-inline-block ms-2">
        <option value="">Wszystkie</option>
        @foreach (var role in availableRoles)
        {
            @if (role == selectedRole)
            {
                <option value="@role" selected>@role</option>
            }
            else
            {
                <option value="@role">@role</option>
            }
        }
    </select>
</form>


<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Email</th>
            <th>Imię i nazwisko</th>
            <th>Stanowisko</th>
            <th>Role</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.FullName</td>
                <td>@user.Position</td>
                <td>@string.Join(", ", user.Roles)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary me-1">Edytuj</a>
                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline" onsubmit="return confirm('Czy na pewno chcesz usunąć tego użytkownika?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
