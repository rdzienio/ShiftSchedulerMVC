@model List<ShiftSchedulerMVC.Models.UserViewModel>
@{
    ViewData["Title"] = "Panel administratora";
    var roles = ViewBag.AvailableRoles as List<string> ?? new List<string>();
    var selectedRole = ViewBag.RoleFilter as string ?? "";
    var nameFilter = ViewBag.NameFilter as string ?? "";
    var positionFilter = ViewBag.PositionFilter as string ?? "";
}

<h2>Użytkownicy</h2>

<a asp-action="Create" class="btn btn-success mb-3">Dodaj użytkownika</a>

<form id="filterForm" method="get" class="mb-3 d-flex gap-2">
    <table class="table table-bordered table-striped align-middle">
        <thead>
            <tr>
                <th>
                    <input type="text" name="nameFilter" class="form-control" placeholder="Imię/Nazwisko/Email" value="@nameFilter" />
                </th>
                <th>
                    <input type="text" name="positionFilter" class="form-control" placeholder="Stanowisko" value="@positionFilter" />
                </th>
                <th>
                    <select name="roleFilter" class="form-select">
                        <option value="">Wszystkie role</option>
                        @foreach (var role in roles)
                        {
                            <option value="@role" selected="@(role == selectedRole)">
                                @role
                            </option>
                        }
                    </select>
                </th>
                <th>
                    <button type="submit" class="btn btn-primary w-100">Filtruj</button>
                </th>
            </tr>
            <tr>
                <th>Email</th>
                <th>Imię i nazwisko</th>
                <th>Role</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>@user.FullName</td>
                    <td>@string.Join(", ", user.Roles)</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary me-1">Edytuj</a>
                        <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Czy na pewno chcesz usunąć tego użytkownika?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</form>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(function () {
            $('#filterForm input, #filterForm select').on('change keyup', function () {
                clearTimeout($.data(this, 'timer'));
                var wait = setTimeout(function () {
                    $('#filterForm').submit();
                }, 500); // opóźnienie 0.5s, żeby nie wysyłało przy każdym znaku
                $(this).data('timer', wait);
            });
        });
    </script>
}
