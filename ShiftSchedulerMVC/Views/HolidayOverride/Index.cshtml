@model List<ShiftSchedulerMVC.Models.HolidayOverride>
@{
    ViewData["Title"] = "Dni świąteczne - nadpisane zmiany";
}

<h2>Ustawienia zmian dla dni świątecznych</h2>

<a asp-action="Create" class="btn btn-success mb-3">Dodaj dzień świąteczny</a>

<table class="table table-bordered">
    <thead class="table-light">
        <tr>
            <th>Data</th>
            <th>Poranna</th>
            <th>Popołudniowa</th>
            <th>Nocna</th>
            <th>Dzienna 12h</th>
            <th>Nocna 12h</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Date.ToString("yyyy-MM-dd")</td>
                <td>@item.MorningCount</td>
                <td>@item.AfternoonCount</td>
                <td>@item.NightCount</td>
                <td>@item.Day12Count</td>
                <td>@item.Night12Count</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Na pewno usunąć?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
