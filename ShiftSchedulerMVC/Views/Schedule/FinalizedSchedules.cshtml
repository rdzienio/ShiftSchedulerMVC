@model Dictionary<string, List<ShiftSchedulerMVC.Models.FinalizedSchedule>>
@{
    ViewData["Title"] = "Zatwierdzony harmonogram";
    var employees = ViewBag.Employees as Dictionary<string, string>;
    var allDates = ViewBag.Dates as List<DateTime>;
    var leaveDays = ViewBag.LeaveDays as HashSet<(string, DateTime)> ?? new();

    Func<DateTime, bool> isWeekend = date =>
        date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;
}

<h2>Zatwierdzony dzień</h2>

<form asp-action="" method="post">
    <table class="table table-bordered text-center">
        <thead>
            <tr>
                <th>Pracownik</th>
                @foreach (var date in allDates)
                {
                    var headerClass = isWeekend(date) ? "weekend-header" : "";
                    <th class="@headerClass">@date.ToString("dd.MM")</th>
                }
                <th>Łącznie godzin</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var kvp in Model)
            {
                var empId = kvp.Key;
                var name = employees.ContainsKey(empId) ? employees[empId] : empId;
                var shifts = kvp.Value;

                var shiftHours = shifts.Sum(s => ShiftDisplay.DurationHours(s.Shift));
                var leaveHours = leaveDays.Count(x => x.Item1 == empId && allDates.Contains(x.Item2)) * 8;
                var totalHours = shiftHours + leaveHours;
                <tr>
                    <td>@name</td>
                    @foreach (var date in allDates)
                    {
                        var key = (empId, date);
                        var entry = shifts.FirstOrDefault(s => s.Date.Date == date);
                        var (code, cssClass) = ShiftDisplay.Table(entry?.Shift, leaveDays.Contains(key));

                        <td class="@cssClass">@code</td>
                    }
                    <td>@totalHours</td>
                </tr>
            }
        </tbody>
    </table>

</form>
<partial name="_ShiftLegend" model="false" />