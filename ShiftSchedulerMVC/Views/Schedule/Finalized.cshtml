@model Dictionary<string, List<ShiftSchedulerMVC.Models.FinalizedSchedule>>

@{
    ViewData["Title"] = "Edytuj dzień";
    var employees = ViewBag.Employees as Dictionary<string, string> ?? new();
    var dates = ViewBag.Dates as List<DateTime> ?? new();
    var leaveDays = ViewBag.LeaveDays as HashSet<(string, DateTime)> ?? new();

    Func<DateTime, bool> isWeekend = date =>
        date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;

    // Zakres aktualnie wyświetlanego okna - przekazywany do edycji/dodawania/usuwania,
    // żeby po akcji wrócić do TEGO SAMEGO widoku (np. całego miesiąca), a nie do jednego dnia.
    var rangeStart = dates.Any() ? dates.First() : DateTime.Today;
    var rangeEnd = dates.Any() ? dates.Last() : DateTime.Today;
}

<h2>Edytuj dzień</h2>


<form method="get" asp-action="Finalized">
    <div class="row mb-3">
        <div class="col">
            <label>Od:</label>
            <input type="date" name="startDate" class="form-control" />
        </div>
        <div class="col">
            <label>Do:</label>
            <input type="date" name="endDate" class="form-control" />
        </div>
        <div class="col d-flex align-items-end">
            <button type="submit" class="btn btn-primary">Filtruj</button>
        </div>
    </div>
</form>

<table class="table table-bordered text-center">
    <thead class="table-light">
        <tr>
            <th>Pracownik</th>
            @foreach (var date in dates)
            {
                var headerClass = isWeekend(date) ? "weekend-header" : "";
                <th class="@headerClass">@date.ToString("dd.MM")</th>
            }
            <th>Łącznie godzin</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var kvp in Model.OrderBy(k => k.Key))
        {
            var empId = kvp.Key;
            var name = employees.ContainsKey(empId) ? employees[empId] : empId;
            var assignments = kvp.Value.ToDictionary(x => x.Date.Date, x => x.Shift);

            var shiftHours = kvp.Value.Sum(s => ShiftDisplay.DurationHours(s.Shift));
            var leaveHours = leaveDays.Count(x => x.Item1 == empId && dates.Contains(x.Item2)) * 8;
            var totalHours = shiftHours + leaveHours;

            <tr>
                <td>@name</td>
                @foreach (var date in dates)
                {
                    var empKey = (empId, date);
                    var isOnLeave = leaveDays.Contains(empKey);
                    var assigned = assignments.ContainsKey(date);
                    var (code, cssClass) = ShiftDisplay.Table(assigned ? assignments[date] : (ShiftType?)null, isOnLeave);

                    <td class="@cssClass">
                        @if (assigned)
                        {
                            var id = Model[empId].FirstOrDefault(x => x.Date.Date == date.Date)?.Id;
                            <a asp-action="EditSchedule" asp-route-id="@id"
                               asp-route-returnStart="@rangeStart.ToString("yyyy-MM-dd")"
                               asp-route-returnEnd="@rangeEnd.ToString("yyyy-MM-dd")"
                               class="btn btn-sm btn-outline-secondary">@code</a>
                        }
                        else
                        {
                            <a asp-action="AddSchedule" asp-route-employeeId="@empId"
                               asp-route-date="@date.ToString("yyyy-MM-dd")"
                               asp-route-returnStart="@rangeStart.ToString("yyyy-MM-dd")"
                               asp-route-returnEnd="@rangeEnd.ToString("yyyy-MM-dd")"
                               class="btn btn-sm btn-outline-success" title="Dodaj zmianę">+</a>
                        }
                    </td>


                }
                <td>@totalHours</td>
            </tr>
        }
    </tbody>
</table>

<partial name="_ShiftLegend" model="false" />
