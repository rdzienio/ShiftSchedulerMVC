@model ShiftSchedulerMVC.Models.ShiftRequirementInput

@{
    ViewData["Title"] = "Ustawienia harmonogramu";
    var countOptions = Enumerable.Range(0, 3).ToList();
}

<h2>Ustaw wymagania dla każdej zmiany</h2>

<form asp-action="Generate" method="post">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="StartDate">Data początkowa</label>
        <input asp-for="StartDate" class="form-control" type="date" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="EndDate">Data końcowa</label>
        <input asp-for="EndDate" class="form-control" type="date" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="WorkingHours">Łączna liczba roboczogodzin w okresie</label>
        <input asp-for="WorkingHours" class="form-control" type="number" />
        <span asp-validation-for="WorkingHours" class="text-danger"></span>
    </div>

    <hr />
    <h4>Zmiany 8-godzinne</h4>

    <div class="form-group">
        <label for="MorningCount">Liczba osób na zmianie porannej (06:00–14:00)</label>
        <select asp-for="MorningCount" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>
    <div class="form-group">
        <label for="AfternoonCount">Liczba osób na zmianie popołudniowej (14:00–22:00)</label>
        <select asp-for="AfternoonCount" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>
    <div class="form-group">
        <label for="NightCount">Liczba osób na zmianie nocnej (22:00–06:00)</label>
        <select asp-for="NightCount" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>

    <hr />
    <h4>Zmiany 12-godzinne (opcjonalne)</h4>

    <div class="form-group">
        <label for="Day12Count">Liczba osób na zmianie dziennej 12h (06:00–18:00)</label>
        <select asp-for="Day12Count" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>
    <div class="form-group">
        <label for="Night12Count">Liczba osób na zmianie nocnej 12h (18:00–06:00)</label>
        <select asp-for="Night12Count" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>

    <hr />
    <h4>Wymagania weekendowe</h4>

    <div class="form-group">
        <label for="SaturdayMorningCount">Sobota – zmiana poranna</label>
        <select asp-for="SaturdayMorningCount" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>
    <div class="form-group">
        <label for="SaturdayAfternoonCount">Sobota – zmiana popołudniowa</label>
        <select asp-for="SaturdayAfternoonCount" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>
    <div class="form-group">
        <label for="SaturdayNightCount">Sobota – zmiana nocna</label>
        <select asp-for="SaturdayNightCount" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>
    <div class="form-group">
        <label for="SaturdayDay12Count">Sobota – zmiana dzienna 12h</label>
        <select asp-for="SaturdayDay12Count" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>
    <div class="form-group">
        <label for="SaturdayNight12Count">Sobota – zmiana nocna 12h</label>
        <select asp-for="SaturdayNight12Count" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>

    <div class="form-group">
        <label for="SundayMorningCount">Niedziela – zmiana poranna</label>
        <select asp-for="SundayMorningCount" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>
    <div class="form-group">
        <label for="SundayAfternoonCount">Niedziela – zmiana popołudniowa</label>
        <select asp-for="SundayAfternoonCount" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>
    <div class="form-group">
        <label for="SundayNightCount">Niedziela – zmiana nocna</label>
        <select asp-for="SundayNightCount" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>
    <div class="form-group">
        <label for="SundayDay12Count">Niedziela – zmiana dzienna 12h</label>
        <select asp-for="SundayDay12Count" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>
    <div class="form-group">
        <label for="SundayNight12Count">Niedziela – zmiana nocna 12h</label>
        <select asp-for="SundayNight12Count" class="form-control"
                asp-items="@(new SelectList(countOptions))">
        </select>
    </div>

    <button type="submit" class="btn btn-primary mt-3">Generuj harmonogram</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
