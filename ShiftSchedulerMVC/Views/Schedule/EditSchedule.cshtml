@model ShiftSchedulerMVC.Models.FinalizedSchedule
@{
    var employees = ViewBag.AllEmployees as List<ShiftSchedulerMVC.Models.ApplicationUser>;
    var isNew = Model.Id == 0;
    ViewData["Title"] = isNew ? "Dodaj zmianę" : "Edycja zmiany";
    var formAction = isNew ? "AddSchedule" : "EditSchedule";

    // Zakres okna, z którego przyszedł użytkownik – żeby „Zapisz"/„Usuń"/„Anuluj" wróciły
    // do tego samego widoku „Edytuj dzień" (np. całego miesiąca), a nie do jednego dnia.
    var returnStart = ViewBag.ReturnStart as DateTime?;
    var returnEnd = ViewBag.ReturnEnd as DateTime?;
    var hasReturn = returnStart.HasValue && returnEnd.HasValue;
    var returnStartStr = returnStart?.ToString("yyyy-MM-dd");
    var returnEndStr = returnEnd?.ToString("yyyy-MM-dd");
}

<h2>@ViewData["Title"]</h2>

<form asp-action="@formAction" method="post">
    <input type="hidden" asp-for="Id" />
    @if (hasReturn)
    {
        <input type="hidden" name="returnStart" value="@returnStartStr" />
        <input type="hidden" name="returnEnd" value="@returnEndStr" />
    }

    <div class="mb-3">
        <label asp-for="Date" class="form-label">Data</label>
        <input asp-for="Date" class="form-control" type="date" asp-format="{0:yyyy-MM-dd}" readonly />
    </div>

    <div class="mb-3">
        <label asp-for="Shift" class="form-label">Zmiana</label>
        <select asp-for="Shift" class="form-control" asp-items="Html.GetEnumSelectList<ShiftType>()"></select>
    </div>

    <div class="mb-3">
        <label asp-for="EmployeeId" class="form-label">Pracownik</label>
        <select asp-for="EmployeeId" class="form-control">
            @foreach (var emp in employees)
            {
                <option value="@emp.Id">@emp.FirstName @emp.LastName</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Zapisz zmiany</button>
    @if (hasReturn)
    {
        <a asp-action="Finalized" asp-route-startDate="@returnStartStr" asp-route-endDate="@returnEndStr"
           class="btn btn-secondary mt-3">Anuluj</a>
    }
    else
    {
        <a asp-action="ApprovedSchedules" class="btn btn-secondary mt-3">Anuluj</a>
    }
</form>

@if (!isNew)
{
    <form asp-action="DeleteSchedule" method="post" class="mt-3"
          onsubmit="return confirm('Na pewno usunąć tę zmianę? Pracownik zostanie zdjęty z tego dnia.');">
        <input type="hidden" name="id" value="@Model.Id" />
        @if (hasReturn)
        {
            <input type="hidden" name="returnStart" value="@returnStartStr" />
            <input type="hidden" name="returnEnd" value="@returnEndStr" />
        }
        <button type="submit" class="btn btn-outline-danger">Usuń zmianę</button>
    </form>
}
